# Required — bearer token for uploads (any strong random string)
ADMIN_TOKEN=change-me

# Optional — external URL of your service (used when generating share links,
# e.g. behind a reverse proxy). Leave blank to derive from request Host header.
# BASE_URL=https://tmp.example.com

# Optional — host port to expose (default 8080)
# HTTP_PORT=8080

# Optional — max upload size in bytes (default 100 MiB = 104857600)
# MAX_SIZE=104857600
